java_library {
    name: "prodx-audit-core",
    srcs: [
        "src/com/android/prodx/runtime/audit/AppendOnlyLedger.kt",
        "src/com/android/prodx/runtime/audit/AuditHealth.kt",
        "src/com/android/prodx/runtime/audit/LedgerHashChain.kt",
        "src/com/android/prodx/runtime/audit/LedgerPartitionManager.kt",
        "src/com/android/prodx/runtime/audit/PrivacyRedactor.kt",
        "src/com/android/prodx/runtime/audit/RecoveryJournal.kt",
        "src/com/android/prodx/runtime/audit/RetentionManager.kt",
        "src/com/android/prodx/runtime/audit/TransactionReservation.kt",
    ],
    sdk_version: "system_current",
}

android_app {
    name: "ProdXAuditService",
    srcs: [
        "aidl/**/*.aidl",
        "src/com/android/prodx/runtime/audit/AuditService.kt",
        "src/com/android/prodx/runtime/audit/AuditShellCommand.kt",
    ],
    aidl: {
        include_dirs: ["frameworks/base/core/java"],
    },
    static_libs: [
        "prodx-audit-core",
        "prodx-contract-runtime",
    ],
    privileged: true,
    platform_apis: true,
    certificate: "platform",
}

android_test {
    name: "ProdXAuditTests",
    manifest: "tests/AndroidManifest.xml",
    srcs: ["tests/src/**/*.kt"],
    static_libs: [
        "androidx.test.ext.junit",
        "androidx.test.runner",
        "prodx-audit-core",
    ],
    instrumentation_for: "ProdXAuditService",
    sdk_version: "system_current",
    certificate: "platform",
    test_suites: ["general-tests"],
}
